rules_version = '2';

// SETUP: same admin UID as in firestore.rules
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == "jPkV5Af2iwYV6jmDQklxXaTIyq93"
        && request.resource.size < 10 * 1024 * 1024;
    }
  }
}
